# ─────────────────────────────────────────────────────────────────────────
# CFCP Bot — environment configuration
#
# Copy this file to ".env" and fill in your real values.
# Never commit your actual ".env" file to GitHub.
# ─────────────────────────────────────────────────────────────────────────

# Your Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# The ID of the Discord server (guild) this bot runs in.
# Enable Developer Mode in Discord settings, then right-click your
# server icon -> "Copy Server ID"
GUILD_ID=000000000000000000

# The ID of the role that should have admin access to the CFCP admin
# panel and admin-only commands.
# Right-click the role in Server Settings -> Roles -> "Copy Role ID"
#
# IMPORTANT: This must be a real, non-zero role ID. If left as 0 or
# unset, NO ONE will be able to use admin functions, and the bot will
# refuse to start (see config.validate_config()).
ADMIN_ROLE_ID=000000000000000000
